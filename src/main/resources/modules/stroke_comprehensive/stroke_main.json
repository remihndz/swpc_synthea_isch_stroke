{
  "name": "Comprehensive Stroke Clinical Trial",
  "remarks": [
    "Main orchestrator module for comprehensive stroke care pathway",
    "Integrates stroke subtypes, investigations, clinical scores, and interventions",
    "Tracks mRS and NIHSS at specific timepoints for clinical trial",
    "Supports TIA, ischemic (with TOAST classification), and hemorrhagic strokes"
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Set_Baseline_mRS_Timepoint"
    },
    "Terminal": {
      "type": "Terminal"
    },
    "Set_Baseline_mRS_Timepoint": {
      "type": "SetAttribute",
      "attribute": "stroke_score_timepoint",
      "value": "baseline",
      "direct_transition": "Set_Baseline_mRS_Target"
    },
    "Set_Baseline_mRS_Target": {
      "type": "SetAttribute",
      "attribute": "stroke_score_target_attribute",
      "value": "baseline_mrs",
      "direct_transition": "Baseline_mRS_Recording"
    },
    "Baseline_mRS_Recording": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/clinical_scores/mrs_computation",
      "remarks": [
        "Baseline mRS is generated by the Java regression scorer"
      ],
      "direct_transition": "Stroke_Event_Trigger"
    },
    "Stroke_Event_Trigger": {
      "type": "Delay",
      "exact": {
        "quantity": 30,
        "unit": "days"
      },
      "remarks": [
        "Delay before stroke event - provides baseline period"
      ],
      "direct_transition": "Classify_Stroke_Subtype"
    },
    "Classify_Stroke_Subtype": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/stroke_subtypes",
      "direct_transition": "Emergency_Admission_Encounter"
    },
    "Emergency_Admission_Encounter": {
      "type": "Encounter",
      "encounter_class": "emergency",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": 50849002,
          "display": "Emergency room admission (procedure)"
        }
      ],
      "reason": "stroke_condition",
      "direct_transition": "Order_Imaging_Bundle"
    },
    "Order_Imaging_Bundle": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/investigations/imaging_bundle",
      "direct_transition": "Set_NIHSS_Admission_Timepoint"
    },
    "Set_NIHSS_Admission_Timepoint": {
      "type": "SetAttribute",
      "attribute": "stroke_score_timepoint",
      "value": "admission",
      "direct_transition": "Set_NIHSS_Admission_Target"
    },
    "Set_NIHSS_Admission_Target": {
      "type": "SetAttribute",
      "attribute": "stroke_score_target_attribute",
      "value": "nihss_admission",
      "direct_transition": "NIHSS_Admission"
    },
    "NIHSS_Admission": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/clinical_scores/nihss_computation",
      "remarks": [
        "NIHSS at admission uses the Java regression scorer"
      ],
      "direct_transition": "Administer_Interventions"
    },
    "Administer_Interventions": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/stroke_interventions",
      "direct_transition": "End_Emergency_Encounter"
    },
    "End_Emergency_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Three_Month_Followup_Delay"
    },
    "Three_Month_Followup_Delay": {
      "type": "Delay",
      "exact": {
        "quantity": 3,
        "unit": "months"
      },
      "direct_transition": "Three_Month_Followup_Encounter"
    },
    "Three_Month_Followup_Encounter": {
      "type": "Encounter",
      "encounter_class": "ambulatory",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": 390906007,
          "display": "Follow-up encounter"
        }
      ],
      "reason": "stroke_condition",
      "direct_transition": "Set_NIHSS_3_Month_Timepoint"
    },
    "Set_NIHSS_3_Month_Timepoint": {
      "type": "SetAttribute",
      "attribute": "stroke_score_timepoint",
      "value": "three_month",
      "direct_transition": "Set_NIHSS_3_Month_Target"
    },
    "Set_NIHSS_3_Month_Target": {
      "type": "SetAttribute",
      "attribute": "stroke_score_target_attribute",
      "value": "nihss_3_month",
      "direct_transition": "NIHSS_3_Month"
    },
    "NIHSS_3_Month": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/clinical_scores/nihss_computation",
      "remarks": [
        "NIHSS at 3 months uses the Java regression scorer"
      ],
      "direct_transition": "Set_mRS_3_Month_Timepoint"
    },
    "Set_mRS_3_Month_Timepoint": {
      "type": "SetAttribute",
      "attribute": "stroke_score_timepoint",
      "value": "three_month",
      "direct_transition": "Set_mRS_3_Month_Target"
    },
    "Set_mRS_3_Month_Target": {
      "type": "SetAttribute",
      "attribute": "stroke_score_target_attribute",
      "value": "mRS_3_month",
      "direct_transition": "mRS_3_Month"
    },
    "mRS_3_Month": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/clinical_scores/mrs_computation",
      "remarks": [
        "mRS at 3 months uses the Java regression scorer"
      ],
      "direct_transition": "End_3_Month_Encounter"
    },
    "End_3_Month_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Six_Month_Followup_Delay"
    },
    "Six_Month_Followup_Delay": {
      "type": "Delay",
      "exact": {
        "quantity": 3,
        "unit": "months"
      },
      "direct_transition": "Six_Month_Followup_Encounter"
    },
    "Six_Month_Followup_Encounter": {
      "type": "Encounter",
      "encounter_class": "ambulatory",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": 390906007,
          "display": "Follow-up encounter"
        }
      ],
      "reason": "stroke_condition",
      "direct_transition": "Set_mRS_6_Month_Timepoint"
    },
    "Set_mRS_6_Month_Timepoint": {
      "type": "SetAttribute",
      "attribute": "stroke_score_timepoint",
      "value": "six_month",
      "direct_transition": "Set_mRS_6_Month_Target"
    },
    "Set_mRS_6_Month_Target": {
      "type": "SetAttribute",
      "attribute": "stroke_score_target_attribute",
      "value": "mRS_6_month",
      "direct_transition": "mRS_6_Month"
    },
    "mRS_6_Month": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/clinical_scores/mrs_computation",
      "remarks": [
        "mRS at 6 months uses the Java regression scorer"
      ],
      "direct_transition": "End_6_Month_Encounter"
    },
    "End_6_Month_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Terminal"
    }
  },
  "gmf_version": 2
}
