{
  "name": "Imaging and Investigation Bundle",
  "remarks": [
    "Orchestrates all stroke-related investigations",
    "Orders blood tests, ECG, NCCT, CTA, and TEE (if appropriate)"
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Order_Blood_Tests"
    },
    "Terminal": {
      "type": "Terminal"
    },
    "Order_Blood_Tests": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/investigations/blood_tests",
      "direct_transition": "Order_ECG"
    },
    "Order_ECG": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/investigations/ecg_module",
      "direct_transition": "Order_NCCT"
    },
    "Order_NCCT": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/investigations/ncct_module",
      "direct_transition": "Order_CTA"
    },
    "Order_CTA": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/investigations/cta_module",
      "direct_transition": "Check_For_TEE"
    },
    "Check_For_TEE": {
      "type": "Simple",
      "conditional_transition": [
        {
          "transition": "Order_TEE",
          "condition": {
            "condition_type": "Attribute",
            "attribute": "stroke_toast_type",
            "operator": "==",
            "value": "Cardioembolic"
          }
        },
        {
          "transition": "Terminal"
        }
      ]
    },
    "Order_TEE": {
      "type": "CallSubmodule",
      "submodule": "stroke_comprehensive/investigations/tee_module",
      "direct_transition": "Terminal"
    }
  },
  "gmf_version": 2
}
