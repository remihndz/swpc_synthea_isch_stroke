{
  "name": "Stroke-Specific Interventions",
  "remarks": [
    "Routes subtype-specific medications and procedures",
    "Ischemic: alteplase, clopidogrel, statin",
    "TIA: clopidogrel, statin",
    "Hemorrhagic: BP-lowering medications (calls hypertension_medication module)"
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Check_Stroke_Type"
    },
    "Terminal": {
      "type": "Terminal"
    },
    "Check_Stroke_Type": {
      "type": "Simple",
      "conditional_transition": [
        {
          "transition": "TIA_Interventions",
          "condition": {
            "condition_type": "Attribute",
            "attribute": "stroke_type",
            "operator": "==",
            "value": "TIA"
          }
        },
        {
          "transition": "Ischemic_Interventions",
          "condition": {
            "condition_type": "Attribute",
            "attribute": "stroke_type",
            "operator": "==",
            "value": "Ischemic"
          }
        },
        {
          "transition": "Hemorrhagic_Interventions",
          "condition": {
            "condition_type": "Attribute",
            "attribute": "stroke_type",
            "operator": "==",
            "value": "Hemorrhagic"
          }
        },
        {
          "transition": "Terminal"
        }
      ]
    },
    "TIA_Interventions": {
      "type": "CallSubmodule",
      "submodule": "medications/statin",
      "direct_transition": "Terminal"
    },
    "Ischemic_Interventions": {
      "type": "Simple",
      "direct_transition": "Administer_Alteplase"
    },
    "Administer_Alteplase": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": 1804799,
          "display": "Alteplase 100 MG Injection"
        }
      ],
      "assign_to_attribute": "stroke_medication_thrombolytic",
      "remarks": [
        "tPA (alteplase) administered for acute ischemic stroke within thrombolytic window"
      ],
      "direct_transition": "Check_Thrombectomy_Candidate"
    },
    "Check_Thrombectomy_Candidate": {
      "type": "Simple",
      "conditional_transition": [
        {
          "transition": "Mechanical_Thrombectomy",
          "condition": {
            "condition_type": "Attribute",
            "attribute": "thrombectomy_candidate",
            "operator": "==",
            "value": true
          }
        },
        {
          "transition": "Administer_Clopidogrel"
        }
      ]
    },
    "Mechanical_Thrombectomy": {
      "type": "Procedure",
      "assign_to_attribute": "stroke_procedure_thrombectomy",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": 433112001,
          "display": "Mechanical thrombectomy"
        }
      ],
      "duration": {
        "low": 30,
        "high": 60,
        "unit": "minutes"
      },
      "remarks": [
        "Performed for large vessel occlusion when CTA identifies thrombectomy candidacy"
      ],
      "direct_transition": "Administer_Clopidogrel"
    },
    "Administer_Clopidogrel": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": 309362,
          "display": "Clopidogrel 75 MG Oral Tablet"
        }
      ],
      "assign_to_attribute": "stroke_medication_antiplatelet",
      "direct_transition": "Administer_Statin"
    },
    "Administer_Statin": {
      "type": "CallSubmodule",
      "submodule": "medications/statin",
      "direct_transition": "Terminal"
    },
    "Hemorrhagic_Interventions": {
      "type": "Simple",
      "direct_transition": "BP_Lowering_Medication"
    },
    "BP_Lowering_Medication": {
      "type": "CallSubmodule",
      "submodule": "medications/hypertension_medication",
      "remarks": [
        "Call hypertension medication module to prescribe BP-lowering agents",
        "For hemorrhagic stroke: goal SBP <140 mmHg"
      ],
      "direct_transition": "Set_BP_Lowering_Treatment"
    },
    "Set_BP_Lowering_Treatment": {
      "type": "SetAttribute",
      "attribute": "stroke_medication_bp_lowering",
      "value": true,
      "direct_transition": "Terminal"
    }
  },
  "gmf_version": 2
}
