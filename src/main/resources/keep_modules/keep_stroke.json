{
  "name": "Keep Stroke Patients",
  "remarks": [
    "Keeps patients with persistent evidence of any stroke presentation,",
    "including TIA, ischemic stroke, or hemorrhagic stroke.",
    "Uses durable attributes rather than active-condition checks."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "conditional_transition": [
        {
          "transition": "Keep",
          "condition": {
            "condition_type": "Or",
            "conditions": [
              {
                "condition_type": "Attribute",
                "attribute": "had_stroke",
                "operator": "==",
                "value": true
              },
              {
                "condition_type": "Attribute",
                "attribute": "stroke_type",
                "operator": "is not nil"
              },
              {
                "condition_type": "Attribute",
                "attribute": "stroke_condition",
                "operator": "is not nil"
              },
              {
                "condition_type": "Attribute",
                "attribute": "stroke_history",
                "operator": "is not nil"
              }
            ]
          }
        },
        {
          "transition": "Terminal"
        }
      ]
    },
    "Terminal": {
      "type": "Terminal"
    },
    "Keep": {
      "type": "Terminal"
    }
  },
  "gmf_version": 2
}
